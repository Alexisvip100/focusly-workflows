# Configuración de base de datos PostgreSQL con asyncpg
DATABASE_URL=postgresql+asyncpg://usuario:contraseña@localhost:5432/focusly

# Autenticación JWT
JWT_SECRET=tu_secreto_para_jwt_aqui

# Integración con Google OAuth
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_REDIRECT_URI=postmessage

# Inteligencia Artificial (Gemini API)
GOOGLE_GENERATIVE_AI_API_KEY=tu_api_key_de_gemini

# Configuración del servidor y Webhooks
WEBHOOK_URL=http://localhost:3000
ENV=development

# Proveedor de Emails (Resend)
RESEND_API_KEY=re_tu_resend_api_key
